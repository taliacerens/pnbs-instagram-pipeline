# Environment Variables — copy this file to .env and fill in your values
# NEVER commit .env to git (it's in .gitignore)

# Required — get yours at https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# Optional but recommended — use a DEDICATED dummy Instagram account, NOT your main one.
# Without these, scraping still runs but may hit rate limits faster.
INSTAGRAM_USERNAME=your_dummy_instagram_account
INSTAGRAM_PASSWORD=your_password
